# AI features (Discover internships)
# Copy this file to .env.local and fill in the keys for the option you want.

# ---- Recommended: fully free (no credit card) ----
# Web search via Tavily + structuring via Google Gemini. Needs BOTH keys.
# Tavily free key (1,000 searches/month): https://app.tavily.com
TAVILY_API_KEY=
# Google Gemini free key: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ---- Fallback: Vercel AI Gateway (usage-billed) ----
# Perplexity Sonar + Claude. Used only if the free keys above are not set.
# vercel.com -> AI Gateway -> API Keys
AI_GATEWAY_API_KEY=

# Note: a Gemini key alone can search the web only if you enable billing on the
# Google Cloud project (Search grounding is not on the pure free tier).
