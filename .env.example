# AI features (Discover internships)
# Copy this file to .env.local and fill in ONE of the options below.

# Option A (recommended, free): Google Gemini via AI Studio.
# Free API key with generous limits; uses Google Search grounding for live web search.
# Get one at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Option B (fallback, usage-billed): Vercel AI Gateway.
# Uses Perplexity Sonar + Claude. Get a key at vercel.com -> AI Gateway -> API Keys.
# Only used if GOOGLE_GENERATIVE_AI_API_KEY is not set.
AI_GATEWAY_API_KEY=

# On Vercel deployments you can use OIDC for the Gateway instead of a key.
