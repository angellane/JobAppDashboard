# AI features (Discover internships)
# Copy this file to .env.local and fill in a key.

# ---- Recommended: JSearch (real job listings from Google for Jobs) ----
# Structured, current, location-filtered listings — the reliable option.
# Free: 200 requests/month, no credit card. https://www.openwebninja.com/api/jsearch
JSEARCH_API_KEY=

# ---- Optional fallback: general web search (older approach) ----
# Only used if JSEARCH_API_KEY is not set. Results are far less reliable.
# Tavily free key: https://app.tavily.com   Gemini free key: https://aistudio.google.com/apikey
TAVILY_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ---- Optional fallback: Vercel AI Gateway (usage-billed) ----
AI_GATEWAY_API_KEY=
